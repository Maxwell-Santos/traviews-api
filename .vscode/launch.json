{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug TS with Nodemon",
      "runtimeExecutable": "nodemon",
      "runtimeArgs": ["--inspect", "--require", "ts-node/register", "src/index.ts"],
      "skipFiles": ["<node_internals>/**"],
      "restart": true,
      "protocol": "inspector",
      "console": "integratedTerminal"
    }
  ]
}
